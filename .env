CA_BILLING_PROJECT=conversationalanalyticsapi
GOOGLE_APPLICATION_CREDENTIALS=CA_API.json
CA_LOCATION=global
ENABLE_GCP_SOURCES_FETCH=true    # Enable/disable (default: true)
GCP_SOURCES_CACHE_TTL=300         # Cache duration in seconds (default: 300)
GCP_SOURCES_FETCH_TIMEOUT=10      # Request timeout in seconds (default: 10)
CA_DEBUG_COT=1